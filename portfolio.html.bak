<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TLOSAO Â· Portfolio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"><link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,700;1,6..96,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
  <style>
    :root {
      --white: #ffffff; --off: #f5f4f2; --black: #0d0d0d;
      --mid: #1a1a1a; --grey: #888888; --light-grey: #e0e0e0;
      --serif: 'Vogue', 'Bodoni Moda', Georgia, serif;
      --sans: 'DM Sans', sans-serif;
    }
    @font-face {
      font-family: 'Vogue';
      src: url('fonts/Vogue.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
      font-display: swap;
    }
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body { background:var(--white); color:var(--black); font-family:var(--sans); font-weight:300; line-height:1.6; overflow-x:hidden; }
    img { display:block; max-width:100%; }

    /* NAV */
    header { position:fixed; top:0; left:0; right:0; z-index:100; background:rgba(255,255,255,0.97); border-bottom:1px solid var(--light-grey); backdrop-filter:blur(8px); display:flex; justify-content:center; align-items:center; padding:0 2.5rem; height:64px; gap:3rem; }
    .nav-logo { font-family:var(--serif); font-size:1.15rem; font-weight:400; letter-spacing:0.12em; color:var(--black); text-decoration:none; text-transform:uppercase; position:absolute; left:2.5rem; }
    h1, h2, h3, h4, h5, h6,
    .page-title,
    .section-title,
    .hero-title,
    .cta-title,
    .legal-content h2 {
      font-family:var(--serif);
      text-transform:uppercase;
      letter-spacing:0.08em;
      word-spacing:-0.04em;
      font-weight:400;
      line-height:1.05;
    }
    .nav-center { display:flex; gap:2.5rem; align-items:center; }
    .nav-center a { font-size:0.72rem; font-weight:400; letter-spacing:0.12em; text-transform:uppercase; text-decoration:none; color:var(--grey); transition:color 0.2s; padding-bottom:2px; border-bottom:1px solid transparent; }
    .nav-center a:hover, .nav-center a.active { color:var(--black); border-bottom-color:var(--black); }
    .nav-right { display:flex; justify-content:center; align-items:center; gap:2rem; position:absolute; right:2.5rem; }
    .nav-email { font-size:0.72rem; color:var(--grey); text-decoration:none; letter-spacing:0.04em; transition:color 0.2s; }
    .nav-email:hover { color:var(--black); }
    .nav-cta { background:var(--black); color:var(--white); padding:0.65rem 1.4rem; font-size:0.68rem; letter-spacing:0.12em; text-transform:uppercase; text-decoration:none; font-weight:500; white-space:nowrap; transition:background 0.2s; }
    .nav-cta:hover { background:#333; }

    /* PAGE HEADER */
    .page-hero { padding:8rem 4rem 4rem; background:var(--off); border-bottom:1px solid var(--light-grey); }
    .page-tag { font-size:0.65rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--grey); margin-bottom:0.8rem; display:flex; align-items:center; gap:0.8rem; }
    .page-tag::before { content:''; display:block; width:25px; height:1px; background:var(--grey); }
    .page-title { font-family:var(--serif); font-size:clamp(2.5rem,6vw,5rem); font-weight:500; text-transform:uppercase; letter-spacing:0.08em; line-height:1; color:var(--black); }

    /* SECTIONS */
    section { padding:5rem 4rem; }
    .section-tag { font-size:0.65rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--grey); margin-bottom:0.8rem; display:flex; align-items:center; gap:0.8rem; }
    .section-tag::before { content:''; display:block; width:25px; height:1px; background:var(--grey); }
    .section-title { font-family:var(--serif); font-size:clamp(1.8rem,3.5vw,3rem); font-weight:500; text-transform:uppercase; line-height:1.05; letter-spacing:0.18em; margin-bottom:1.5rem; }

    /* PORTFOLIO GRID */
    .work-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:1.5px; background:var(--light-grey); } gap:1.5px; background:var(--light-grey); }
    .work-item { position:relative; overflow:hidden; cursor:pointer; background:var(--white); aspect-ratio:9/16; }`n    .work-item.horizontal { aspect-ratio:16/9; }
    .work-img { width:100%; height:100%; object-fit:cover; transition:transform 0.5s ease; }
    .work-item:hover .work-img { transform:scale(1.04); }
    .work-info { position:absolute; inset:0; background:linear-gradient(to top,rgba(0,0,0,0.85) 0%,transparent 60%); display:flex; flex-direction:column; justify-content:flex-end; padding:1.5rem; opacity:0; transition:opacity 0.3s; }
    .work-item:hover .work-info { opacity:1; }
    .work-tag { font-size:0.62rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.7); margin-bottom:0.3rem; }
    .work-name { font-family:var(--serif); font-size:1.3rem; color:#fff; line-height:1.2; }
    .work-desc { font-size:0.75rem; color:rgba(255,255,255,0.6); margin-top:0.2rem; }

    /* LIGHTBOX */
    .lb { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.93); z-index:300; align-items:center; justify-content:center; padding:2rem; cursor:zoom-out; }
    .lb.open { display:flex; }
    .lb img { max-width:90vw; max-height:90vh; object-fit:contain; }
    .lb-close { position:fixed; top:1.2rem; right:1.5rem; font-size:1.8rem; color:#888; cursor:pointer; background:none; border:none; z-index:301; transition:color 0.2s; }
    .lb-close:hover { color:#fff; }

    /* SERVICES */
    .services-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:var(--light-grey); }
    .service-card { background:var(--white); padding:2.5rem 2rem; transition:background 0.25s; }
    .service-card:hover { background:var(--black); color:var(--white); }
    .service-num { font-family:var(--serif); font-size:2.5rem; font-weight:400; color:var(--light-grey); line-height:1; margin-bottom:2rem; transition:color 0.25s; }
    .service-card:hover .service-num { color:#333; }
    .service-title { font-size:0.78rem; font-weight:500; letter-spacing:0.12em; text-transform:uppercase; margin-bottom:1rem; line-height:1.4; }
    .service-desc { font-size:0.82rem; color:#777; line-height:1.7; transition:color 0.25s; }
    .service-card:hover .service-desc { color:#aaa; }
    .service-price { margin-top:2rem; font-family:var(--serif); font-size:1rem; font-style:italic; }
    .service-card:hover .service-price { color:var(--white); }

    /* ABOUT */
    .about-grid { display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center; }
    .about-img { width:100%; object-fit:cover; filter:grayscale(20%); }
    .about-text p { font-size:0.88rem; color:#555; line-height:1.9; margin-bottom:1rem; }
    .about-text strong { color:var(--black); font-weight:500; }
    .tools-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:0.5rem; margin-top:2.5rem; }
    .tool-tag { border:1px solid var(--light-grey); padding:0.5rem 0.8rem; font-size:0.68rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--grey); text-align:center; transition:border-color 0.2s, color 0.2s; }
    .tool-tag:hover { border-color:var(--black); color:var(--black); }

    /* CTA BANNER */
    .cta-banner { background:var(--black); color:var(--white); padding:5rem 4rem; text-align:center; }
    .cta-title { font-family:var(--serif); font-size:clamp(2rem,5vw,4rem); font-weight:500; text-transform:uppercase; letter-spacing:0.18em; line-height:1.1; margin-bottom:1.2rem; }
    .cta-sub { font-size:0.88rem; color:#aaa; max-width:480px; margin:0 auto 2.5rem; line-height:1.8; }
    .btn-white { display:inline-block; background:var(--white); color:var(--black); padding:0.85rem 2rem; font-size:0.72rem; letter-spacing:0.14em; text-transform:uppercase; text-decoration:none; font-weight:500; transition:background 0.2s; }
    .btn-white:hover { background:var(--light-grey); }

    /* BUTTONS */
    .btn-outline { display:inline-flex; align-items:center; gap:0.7rem; border:1.5px solid var(--black); color:var(--black); padding:0.8rem 1.6rem; font-size:0.72rem; letter-spacing:0.14em; text-transform:uppercase; text-decoration:none; font-weight:500; transition:background 0.2s, color 0.2s; width:fit-content; }
    .btn-outline:hover { background:var(--black); color:var(--white); }

    /* FOOTER */
    footer { background:var(--black); color:var(--white); padding:1.4rem 2.5rem; display:flex; align-items:center; gap:1.5rem; flex-wrap:wrap; }
    .footer-item { display:flex; align-items:center; gap:0.6rem; font-size:0.72rem; color:#aaa; text-decoration:none; transition:color 0.2s; white-space:nowrap; }
    .footer-item:hover { color:var(--white); }
    .footer-sep { width:1px; height:16px; background:#333; flex-shrink:0; }
    .footer-legal { margin-left:auto; font-size:0.65rem; letter-spacing:0.12em; text-transform:uppercase; color:#555; text-decoration:none; display:flex; align-items:center; gap:0.8rem; transition:color 0.2s; }
    .footer-legal::before { content:''; display:block; width:20px; height:1px; background:#333; }
    .footer-legal:hover { color:#aaa; }

    /* MENTIONS LÃ‰GALES PAGE */
    .legal-content { max-width:800px; padding:8rem 4rem 6rem; }
    .legal-content h2 { font-family:var(--serif); font-size:1.4rem; font-weight:500; text-transform:uppercase; letter-spacing:0.18em; margin:2.5rem 0 0.8rem; }
    .legal-content p, .legal-content li { font-size:0.88rem; color:#555; line-height:1.9; margin-bottom:0.8rem; }
    .legal-content li { margin-left:1.5rem; }

    /* MOBILE */
    @media(max-width:900px) {
      header { grid-template-columns:1fr auto; }
      .nav-center { display:none; }
      .nav-email { display:none; }
      .work-grid { grid-template-columns:1fr 1fr; }
      .services-grid { grid-template-columns:1fr 1fr; }
      .about-grid { grid-template-columns:1fr; }
      section { padding:4rem 1.5rem; }
      .page-hero { padding:7rem 1.5rem 3rem; }
      .legal-content { padding:7rem 1.5rem 4rem; }
    }
    @media(max-width:600px) {
      .work-grid { grid-template-columns:1fr; }
      .services-grid { grid-template-columns:1fr; }
      .tools-grid { grid-template-columns:repeat(2,1fr); }
      footer { gap:1rem; }
    }
</style>
</head>
